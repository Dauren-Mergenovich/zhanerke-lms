{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js?path=/api/$1"
    },
    {
      "source": "/student",
      "destination": "/api/index.js?path=/student"
    },
    {
      "source": "/admin",
      "destination": "/api/index.js?path=/admin"
    },
    {
      "source": "/admin/dashboard",
      "destination": "/api/index.js?path=/admin/dashboard"
    },
    {
      "source": "/reset-password",
      "destination": "/api/index.js?path=/reset-password"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js?path=/$1"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "{*.html,*.css,*.js,Фото/**,Лого и картинки/**,Дипломы и Сертификаты/**}"
    }
  }
}
